rules_version = '2';

// daywise Firestore security rules.
// Each user can only read and write their own document tree under /users/{uid},
// including all subcollections (timetable, and future entries/programs/reports).
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Broadcast announcements: any signed-in user can read; only admins can write.
    // Keep this admin list in sync with ADMIN_EMAILS in src/lib/admin.ts.
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email in ['lachlan.odea@wisetechglobal.com'];
    }
    match /announcements/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
